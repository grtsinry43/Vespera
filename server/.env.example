# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database Configuration
# SQLite (default - 轻量级方案)
SQLITE_PATH=monitor.db

# Agent Authentication
# 生成强随机令牌: openssl rand -hex 32
AGENT_REGISTRATION_TOKEN=change-this-to-a-secure-random-token-at-least-32-characters

# JWT Authentication
# 生成强随机密钥: openssl rand -hex 32
JWT_SECRET=change-this-to-a-secure-random-jwt-secret-at-least-32-characters

# Initial Admin User (首次启动时创建)
# 创建后请立即删除这些环境变量!
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-immediately

# Logging
RUST_LOG=vespera=debug,tower_http=debug
